# AgentRegistry as an image: the registry's read-only internet face.
# The declarations are baked in at build — the image IS the published
# registry at that release; admission stays in the record.
FROM golang:1.25.7 AS build
WORKDIR /src
COPY go.mod go.sum ./
RUN go mod download
COPY . .
RUN CGO_ENABLED=0 go build -o /agentregistry ./cmd/agentregistry

FROM gcr.io/distroless/static:nonroot
COPY --from=build /agentregistry /agentregistry
COPY registry/ /registry/
WORKDIR /
ENTRYPOINT ["/agentregistry", "-addr", ":8080", "-dir", "/registry"]
